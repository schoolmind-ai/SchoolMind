{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SchoolMind: create environment",
      "type": "process",
      "command": "py",
      "args": ["-m", "venv", ".venv"],
      "problemMatcher": []
    },
    {
      "label": "SchoolMind: install dependencies",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "dependsOn": "SchoolMind: create environment",
      "problemMatcher": []
    },
    {
      "label": "SchoolMind: run tests",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["run_tests.py"],
      "problemMatcher": []
    }
  ]
}
