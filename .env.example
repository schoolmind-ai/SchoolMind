APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars

# Local/dev default. Production must use PostgreSQL unless ALLOW_SQLITE_IN_PRODUCTION=true is set for a controlled demo.
# SchoolMind AI pricing uses Standard ($9.99/mo), Pro ($49/mo), and Custom/guided pilot. Internal plan keys remain starter/growth/scale for backward compatibility.
DATABASE_ENGINE=sqlite
DATABASE_PATH=instance/schoolmind.sqlite3
DATABASE_URL=
DATABASE_SSLMODE=
DATABASE_POOLING_MODE=external
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_APPLICATION_NAME=schoolmind-ai
ALLOW_SQLITE_IN_PRODUCTION=false

# Render + Supabase production example:
# DATABASE_ENGINE=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
# DATABASE_SSLMODE=require
# DATABASE_POOLING_MODE=external
# DATABASE_CONNECT_TIMEOUT_SECONDS=10
# DATABASE_STATEMENT_TIMEOUT_MS=30000
# DATABASE_APPLICATION_NAME=schoolmind-ai
# AUTO_INIT_DB=true
# RUN_MIGRATIONS_ON_BOOT=true

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=schoolmind_session
AUTO_INIT_DB=true
RUN_MIGRATIONS_ON_BOOT=true
SEED_DEMO_DATA=true
ENABLE_DEMO_SEED=true
DEMO_MODE=false
ALLOW_SELF_REGISTER=true
SCHOOLMIND_REQUIRE_INVITES=false
ALLOW_DEMO_DATA_IN_PRODUCTION=false
PUBLIC_BASE_URL=http://localhost:5000
CHECKOUT_STARTER_URL=
CHECKOUT_GROWTH_URL=
CHECKOUT_SCALE_URL=
CHECKOUT_STARTER_MONTHLY_URL=
CHECKOUT_STARTER_SIX_MONTH_URL=
CHECKOUT_STARTER_ANNUAL_URL=
CHECKOUT_GROWTH_MONTHLY_URL=
CHECKOUT_GROWTH_SIX_MONTH_URL=
CHECKOUT_GROWTH_ANNUAL_URL=
CHECKOUT_SCALE_MONTHLY_URL=
CHECKOUT_SCALE_SIX_MONTH_URL=
CHECKOUT_SCALE_ANNUAL_URL=
ALLOW_SCHOOL_ADMIN_MANUAL_BILLING=false
SUPPORT_EMAIL=support@schoolmind.ai
BILLING_WEBHOOK_SECRET=
EMAIL_DELIVERY_MODE=queue
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=support@schoolmind.ai
SMTP_USE_TLS=true
TEST_EMAIL_RECIPIENT=support@schoolmind.ai
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
REQUEST_ID_HEADER=X-Request-ID
# Set true only when the app is behind a trusted proxy/load balancer such as Render.
TRUST_PROXY_HEADERS=false
RATE_LIMIT_BACKEND=memory
CSP_REPORT_ONLY=false
CSP_REPORT_URI=

GROQ_API_KEY=
GROQ_MODEL=
GROQ_TIMEOUT=20

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DEFAULT_ROLE=student
GOOGLE_DEFAULT_SCHOOL_SLUG=pixel-academy
GOOGLE_ALLOW_AUTO_CREATE=false

WEB_CONCURRENCY=1
GUNICORN_THREADS=8

PLATFORM_ADMIN_EMAIL=owner@schoolmind.ai
PLATFORM_ADMIN_PASSWORD=change-this-platform-password
PLATFORM_ADMIN_NAME=Platform Owner
